# ==========================
# Application
# ==========================
NODE_ENV=development
PORT=4000

# ==========================
# Database
# ==========================
DATABASE_URL="postgresql://pruthvi@localhost:5432/logistics_db?schema=public"

# ==========================
# JWT
# ==========================
JWT_SECRET=pruthvi_super_secret_key

# ==========================
# Frontend
# ==========================
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5174

# ==========================
# Assignment
# ==========================
AGENT_ASSIGNMENT_RADIUS_KM=50
ALLOW_PRIVILEGED_SELF_REGISTRATION=true
SKIP_EMAIL_VERIFICATION=true

# ==========================
# Google Maps
# ==========================
GOOGLE_MAPS_API_KEY=PASTE_YOUR_GOOGLE_MAPS_API_KEY_HERE

# ==========================
# Brevo SMTP
# ==========================
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=PASTE_YOUR_BREVO_SMTP_USERNAME
SMTP_PASS=PASTE_YOUR_BREVO_SMTP_KEY
SMTP_FROM=PASTE_YOUR_VERIFIED_SENDER_EMAIL

# ==========================
# Firebase (Optional)
# ==========================
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_CLIENT_EMAIL=YOUR_FIREBASE_CLIENT_EMAIL
FIREBASE_PRIVATE_KEY="YOUR_FIREBASE_PRIVATE_KEY"

# ==========================
# Twilio (Optional)
# ==========================
TWILIO_SID=mock_sid
TWILIO_AUTH_TOKEN=mock_token
TWILIO_FROM=+1234567890